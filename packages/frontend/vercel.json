{
  "buildCommand": "cd ../.. && pnpm --filter @oytiot/shared build && pnpm --filter @oytiot/frontend build",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://oytiotbackend-production.up.railway.app/api/:path*" }
  ]
}
